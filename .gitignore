# --- Data & Large Files ---
# Ignore all CSV files in the data folder
data/*.csv

# Ignore Beam temporary processing folders/files
data/beam-temp-*
data/.temp*

# EXCEPTION: Do NOT ignore the .gitkeep file 
# (This ensures the 'data' folder itself shows up on GitHub)
!data/.gitkeep

# --- Python & Environment ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
env/
.env

# --- Streamlit & OS ---
.streamlit/
.DS_Store
Thumbs.db

# --- Logs ---
*.log